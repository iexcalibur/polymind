{
  "name": "@polymind/ios",
  "version": "0.26.3",
  "description": "AFFiNE Desktop Web application",
  "type": "module",
  "private": true,
  "browser": "src/index.tsx",
  "scripts": {
    "build": "affine bundle",
    "dev": "affine bundle --dev",
