{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch PolyMind Cloud",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "yarn",
      "cwd": "${workspaceFolder}",
      "runtimeArgs": [
        "polymind",
        "@polymind/server",
        "dev"
      ]
    },
    {
      "name": "Launch PolyMind Web",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "yarn",
      "cwd": "${workspaceFolder}",
      "runtimeArgs": [
        "polymind",
        "@polymind/web",
        "dev"
      ]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Debug PolyMind Web",
      "url": "http://localhost:8080"
    }
  ]
}