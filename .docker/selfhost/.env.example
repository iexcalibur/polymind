# select a revision to deploy, available values: stable, beta, canary
POLYMIND_REVISION=stable

# set the port for the server container it will expose the server on
PORT=3010

# set the host for the server for outgoing links
# POLYMIND_SERVER_HTTPS=true
# POLYMIND_SERVER_HOST=polymind.yourdomain.com
# or
# POLYMIND_SERVER_EXTERNAL_URL=https://polymind.yourdomain.com

# position of the database data to persist
DB_DATA_LOCATION=~/.polymind/self-host/postgres/pgdata
# position of the upload data(images, files, etc.) to persist
UPLOAD_LOCATION=~/.polymind/self-host/storage
# position of the configuration files to persist
CONFIG_LOCATION=~/.polymind/self-host/config

# database credentials
DB_USERNAME=polymind
DB_PASSWORD=
DB_DATABASE=polymind
